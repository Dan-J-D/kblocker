#!/bin/bash
set -e

case "$1" in
    remove|upgrade|deconfigure)
        if [ -d /sys/kernel/kblocker ]; then
            echo 0 > /sys/kernel/kblocker/enabled 2>/dev/null || true
            sleep 1
            rmmod kblocker 2>/dev/null || rmmod -f kblocker 2>/dev/null || true
        fi

        for f in \
            /etc/modules-load.d/kblocker.conf \
            /lib/modules/$(uname -r)/extra/kblocker.ko; do
            if [ -f "$f" ] && command -v chattr >/dev/null 2>&1; then
                chattr -i "$f" 2>/dev/null || true
            fi
        done

        HOSTS_MARKER="# kblocker managed entries - do not edit manually"
        if grep -q "$HOSTS_MARKER" /etc/hosts 2>/dev/null; then
            sed -i "/$HOSTS_MARKER/,/^$/d" /etc/hosts
        fi
        ;;
esac